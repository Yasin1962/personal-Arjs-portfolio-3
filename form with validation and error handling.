<!DOCTYPE html>
<html ng-app>
<head>
<script src="https://ajax.googleapis.com/ajax/libs/angularjs/1.8.2/angular.min.js"></script>
</head>

<body>

<form name="myForm">

Email:
<input type="email" ng-model="email" required>
<span ng-show="myForm.$submitted && myForm.email.$error.required">Required</span>
<span ng-show="myForm.email.$error.email">Invalid Email</span><br>

<button ng-click="myForm.$submitted=true">Submit</button>

</form>

</body>
</html>
